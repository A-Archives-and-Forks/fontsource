{
	"name": "fontsource-registry-tools",
	"private": true,
	"type": "module",
	"scripts": {
		"generate": "cd ../.. && pnpm --filter '@fontsource-utils/core' build && node scripts/registry/generate.ts",
		"test": "cd ../.. && pnpm --filter '@fontsource-utils/core' build && vitest run --config scripts/registry/vitest.config.ts",
		"typecheck": "cd ../.. && pnpm --filter '@fontsource-utils/core' build && tsc --noEmit -p scripts/registry/tsconfig.json",
		"validate": "cd ../.. && node scripts/registry/validator.ts"
	},
	"dependencies": {
		"@fontsource-utils/core": "workspace:*",
		"protobufjs": "8.7.1",
		"turndown": "7.2.4",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/node": "catalog:node24",
		"@types/turndown": "5.0.6",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
