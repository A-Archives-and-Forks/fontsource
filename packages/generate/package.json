{
	"name": "@fontsource-utils/generate",
	"version": "0.4.2",
	"description": "A CSS font-face generator",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		},
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"prepack": "pnpm run build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "Ayuhito <hello@ayuhito.com>",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "catalog:node20",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"files": [
		"dist/*"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/fontsource/fontsource/tree/main/packages/generate",
	"repository": {
		"type": "git",
		"url": "https://github.com/fontsource/fontsource",
		"directory": "packages/generate"
	}
}
