{
	"name": "@fontsource-utils/publish",
	"version": "0.4.1",
	"description": "Fontsource Publish CLI",
	"bin": {
		"fontsource-publish": "dist/cli.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "pnpm run build && node ./dist/cli.mjs",
		"prepack": "pnpm run build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "Ayuhito <hello@ayuhito.com>",
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"@npmcli/package-json": "^8.0.0",
		"cac": "^7.0.0",
		"consola": "^3.1.0",
		"defu": "^6.1.2",
		"dotenv": "^17.4.2",
		"execa": "^10.0.0",
		"fs-extra": "^11.1.0",
		"hash-wasm": "^4.9.0",
		"json-stringify-pretty-compact": "^4.0.0",
		"p-queue": "^9.3.1",
		"parse-git-config": "^3.0.0",
		"pathe": "^2.0.3",
		"picocolors": "^1.0.0",
		"semver": "^7.5.1"
	},
	"devDependencies": {
		"@types/folder-hash": "^4.0.2",
		"@types/fs-extra": "^11.0.1",
		"@types/node": "catalog:node20",
		"@types/parse-git-config": "^3.0.1",
		"@types/semver": "^7.5.0",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"files": [
		"dist/*"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "^22.22.2 || >=24.15.0"
	},
	"homepage": "https://github.com/fontsource/fontsource/tree/main/packages/publish",
	"repository": {
		"type": "git",
		"url": "https://github.com/fontsource/fontsource",
		"directory": "packages/publish"
	}
}
