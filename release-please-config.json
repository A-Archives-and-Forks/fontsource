		},
		"packages/core": {
			"component": "core",
			"release-type": "node"
		},
		"packages/publish": {
			"component": "publish",
			"release-type": "node"
		},
		"packages/scss": {
			"component": "scss",
			"release-type": "node"
		}
	}
}
