{
	"name": "fontsource",
	"version": "5.2.0",
	"packageManager": "pnpm@11.14.0",
	"author": "Ayuhito <hello@ayuhito.com>",
	"license": "MIT",
	"private": true,
	"scripts": {
		"build": "pnpm --workspace-concurrency=1 --recursive --if-present run build",
		"build:packages": "pnpm --workspace-concurrency=1 --recursive --filter './packages/*' --if-present run build",
		"check": "biome check .",
		"ci": "pnpm check && pnpm build && pnpm typecheck:all && pnpm test:all && pnpm pack:check",
		"fix": "biome check --write .",
		"pack:check": "pnpm --workspace-concurrency=1 --recursive --filter './packages/*' pack --dry-run",
		"test": "pnpm build:packages && pnpm test:all",
		"test:all": "pnpm --workspace-concurrency=1 --recursive --if-present run test",
		"test:coverage": "pnpm --workspace-concurrency=1 --recursive --if-present run test:coverage",
		"test:packages": "pnpm --workspace-concurrency=1 --recursive --filter './packages/*' --if-present run test",
		"test:watch": "pnpm --recursive --parallel --if-present run test:watch",
		"typecheck": "pnpm build:packages && pnpm typecheck:all",
		"typecheck:all": "pnpm --workspace-concurrency=1 --recursive --if-present run typecheck",
		"typecheck:packages": "pnpm --workspace-concurrency=1 --recursive --filter './packages/*' --if-present run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:"
	},
	"engines": {
		"node": ">=24.18.0 <25",
		"pnpm": ">=11.14.0 <12"
	}
}
